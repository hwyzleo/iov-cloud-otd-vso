<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.hwyz.iov.cloud.otd.vso.service.infrastructure.persistence.mapper.PaymentMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="baseResultMap" type="net.hwyz.iov.cloud.otd.vso.service.infrastructure.persistence.po.PaymentPo">
        <id column="id" property="id" />
        <result column="payment_id" property="paymentId" />
        <result column="payment_no" property="paymentNo" />
        <result column="order_id" property="orderId" />
        <result column="payment_stage" property="paymentStage" />
        <result column="payment_channel" property="paymentChannel" />
        <result column="payment_amount" property="paymentAmount" />
        <result column="payment_status" property="paymentStatus" />
        <result column="initiator_role" property="initiatorRole" />
        <result column="initiator_id" property="initiatorId" />
        <result column="authorized_flag" property="authorizedFlag" />
        <result column="authorized_proof_type" property="authorizedProofType" />
        <result column="external_trade_no" property="externalTradeNo" />
        <result column="pay_time" property="payTime" />
        <result column="fail_reason" property="failReason" />
        <result column="create_time" property="createTime" />
        <result column="create_by" property="createBy" />
        <result column="modify_time" property="modifyTime" />
        <result column="modify_by" property="modifyBy" />
        <result column="row_version" property="rowVersion" />
        <result column="row_valid" property="rowValid" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="baseColumnList">
        t.id, t.payment_id, t.payment_no, t.order_id, t.payment_stage, t.payment_channel,
        t.payment_amount, t.payment_status, t.initiator_role, t.initiator_id, t.authorized_flag,
        t.authorized_proof_type, t.external_trade_no, t.pay_time, t.fail_reason,
        t.create_time, t.create_by, t.modify_time, t.modify_by, t.row_version, t.row_valid
    </sql>

    <!-- 根据订单业务 ID 查询支付记录 -->
    <select id="selectByOrderId" resultMap="baseResultMap">
        SELECT <include refid="baseColumnList"/>
        FROM vso_payment t
        WHERE t.order_id = #{orderId}
        AND t.row_valid = 1
    </select>

</mapper>