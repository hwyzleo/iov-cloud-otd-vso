<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.hwyz.iov.cloud.otd.vso.service.infrastructure.persistence.mapper.ApprovalMapper">

    <resultMap id="baseResultMap" type="net.hwyz.iov.cloud.otd.vso.service.infrastructure.persistence.po.ApprovalPo">
        <id column="id" property="id" />
        <result column="approval_id" property="approvalId" />
        <result column="approval_no" property="approvalNo" />
        <result column="order_id" property="orderId" />
        <result column="approval_type" property="approvalType" />
        <result column="approval_status" property="approvalStatus" />
        <result column="apply_user_id" property="applyUserId" />
        <result column="apply_role" property="applyRole" />
        <result column="apply_reason" property="applyReason" />
        <result column="change_snapshot" property="changeSnapshot" />
        <result column="current_node_no" property="currentNodeNo" />
        <result column="executor_result" property="executorResult" />
        <result column="submit_time" property="submitTime" />
        <result column="finish_time" property="finishTime" />
        <result column="create_time" property="createTime" />
        <result column="create_by" property="createBy" />
        <result column="modify_time" property="modifyTime" />
        <result column="modify_by" property="modifyBy" />
        <result column="row_version" property="rowVersion" />
        <result column="row_valid" property="rowValid" />
    </resultMap>

    <sql id="baseColumnList">
        t.id, t.approval_id, t.approval_no, t.order_id, t.approval_type, t.approval_status,
        t.apply_user_id, t.apply_role, t.apply_reason, t.change_snapshot, t.current_node_no,
        t.executor_result, t.submit_time, t.finish_time, t.create_time, t.create_by,
        t.modify_time, t.modify_by, t.row_version, t.row_valid
    </sql>

    <select id="selectByOrderId" resultMap="baseResultMap">
        SELECT <include refid="baseColumnList"/>
        FROM vso_approval t
        WHERE t.order_id = #{orderId}
        AND t.row_valid = 1
    </select>

</mapper>