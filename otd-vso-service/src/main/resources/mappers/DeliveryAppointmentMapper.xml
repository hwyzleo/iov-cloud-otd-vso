<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.hwyz.iov.cloud.otd.vso.service.infrastructure.persistence.mapper.DeliveryAppointmentMapper">

    <resultMap id="baseResultMap" type="net.hwyz.iov.cloud.otd.vso.service.infrastructure.persistence.po.DeliveryAppointmentPo">
        <id column="id" property="id" />
        <result column="delivery_appointment_id" property="deliveryAppointmentId" />
        <result column="delivery_appointment_no" property="deliveryAppointmentNo" />
        <result column="order_id" property="orderId" />
        <result column="appointment_status" property="appointmentStatus" />
        <result column="delivery_mode" property="deliveryMode" />
        <result column="appointment_time" property="appointmentTime" />
        <result column="appointment_place" property="appointmentPlace" />
        <result column="appointment_store_code" property="appointmentStoreCode" />
        <result column="contact_name" property="contactName" />
        <result column="contact_mobile_encrypted" property="contactMobileEncrypted" />
        <result column="reschedule_reason" property="rescheduleReason" />
        <result column="cancel_reason" property="cancelReason" />
        <result column="operator_id" property="operatorId" />
        <result column="create_time" property="createTime" />
        <result column="create_by" property="createBy" />
        <result column="modify_time" property="modifyTime" />
        <result column="modify_by" property="modifyBy" />
        <result column="row_version" property="rowVersion" />
        <result column="row_valid" property="rowValid" />
    </resultMap>

    <sql id="baseColumnList">
        t.id, t.delivery_appointment_id, t.delivery_appointment_no, t.order_id,
        t.appointment_status, t.delivery_mode, t.appointment_time, t.appointment_place,
        t.appointment_store_code, t.contact_name, t.contact_mobile_encrypted,
        t.reschedule_reason, t.cancel_reason, t.operator_id, t.create_time, t.create_by,
        t.modify_time, t.modify_by, t.row_version, t.row_valid
    </sql>

    <select id="selectByOrderId" resultMap="baseResultMap">
        SELECT <include refid="baseColumnList"/>
        FROM vso_delivery_appointment t
        WHERE t.order_id = #{orderId}
        AND t.row_valid = 1
    </select>

</mapper>